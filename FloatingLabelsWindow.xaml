<Window x:Class="Étiquettes_Flottantes.FloatingLabelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Étiquettes"
        Width="800" Height="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="White"
        SnapsToDevicePixels="True">

    <WindowChrome.WindowChrome>
        <!-- CaptionHeight=0 : pas de barre de titre, mais on garde le resize aux bords -->
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="Root"
          Background="White"
          MouseLeftButtonDown="Root_MouseLeftButtonDown"
          PreviewMouseRightButtonDown="Root_PreviewMouseRightButtonDown">
        <Canvas x:Name="CanvasArea" Background="White"/>
    </Grid>
</Window>
