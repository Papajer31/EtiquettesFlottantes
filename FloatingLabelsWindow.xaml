<Window x:Class="Étiquettes_Flottantes.FloatingLabelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Étiquettes"
        Background="White"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        WindowStartupLocation="CenterScreen">

    <!-- Pour permettre le resize avec une fenêtre borderless -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid x:Name="Root"
          Background="White"
          MouseLeftButtonDown="Root_MouseLeftButtonDown"
          PreviewMouseRightButtonDown="Root_PreviewMouseRightButtonDown">

        <!-- IMPORTANT : Background Transparent pour que le Canvas reçoive les clics dans les zones vides -->
        <Canvas x:Name="CanvasArea" Background="Transparent"/>
    </Grid>
</Window>