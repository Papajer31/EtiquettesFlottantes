<Window x:Class="Étiquettes_Flottantes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:Étiquettes_Flottantes"
        mc:Ignorable="d"
        Title="MainWindow"
        MinWidth="760" MinHeight="480"
        Width="760" Height="480"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="#1E1E1E">

    <!-- Fenetre sans bord, avec redimensionnement et coins propres -->
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="10" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border CornerRadius="10" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="1" SnapsToDevicePixels="True">

        <DockPanel LastChildFill="True">

            <!-- ===== Top bar (style VS) ===== -->
            <Grid x:Name="TopBar" Height="40" DockPanel.Dock="Top" Background="#252526" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Zone boutons texte -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnLoadImage" Grid.Column="0" Style="{StaticResource PrimaryButtonStyle}" Width="60" Margin="5,4,4,5"
                            Content=" &#xEABC; " Cursor="Hand" Click="BtnLoadImage_Click" FontSize="24" FontFamily="Segoe Fluent Icons"
                             shell:WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Charger une image de fond"/>
                    <TextBlock x:Name="TxtImageName" Margin="12,0,0,0" FontStyle="Italic" Opacity="0.75" Text="(aucune image)"
                                   Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Boutons fenetre -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowButtonStyle}" ToolTip="Réduire" Click="BtnMinimize_Click">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="12" Cursor=""/>
                    </Button>
                    <Button Style="{StaticResource WindowButtonStyle}" ToolTip="Agrandir / Restaurer" Click="BtnMaxRestore_Click">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE922;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                            <Setter Property="Text" Value="&#xE923;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButtonStyle}" ToolTip="Fermer" Click="BtnClose_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== Contenu ===== -->
            <Grid Background="#1E1E1E" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="InputTextBox" Grid.Row="0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                         FontSize="18" Foreground="White" Background="#252526" BorderBrush="#3A3A3A" BorderThickness="1" Padding="12"
                         SpellCheck.IsEnabled="False" FontFamily="{StaticResource AndikaFont}" Cursor=""/>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnExemple" Style="{StaticResource PrimaryButtonStyle}" Content=" &#xE104; "
                                FontFamily="Segoe Fluent Icons" Margin="0,0,10,0" Width="60" Height="52" FontSize="30"
                                Click="BtnExemple_Click" ToolTip="Charger un fichier texte" FontWeight="Normal"/>
                        <Button x:Name="BtnListeH" Style="{StaticResource PrimaryButtonStyle}" Content=" &#xF596; "
                                FontFamily="Segoe Fluent Icons" Margin="0,0,10,0" Width="60" Height="52" FontSize="34"
                                Click="BtnListeH_Click" ToolTip="Aligner les étiquettes en haut" FontWeight="Normal"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnFontMinus" Style="{StaticResource PrimaryButtonStyle}" Content="&#xE8E7;" Width="60" Height="52"
                                FontFamily="Segoe Fluent Icons" FontSize="34" Margin="0,0,10,0" Cursor="Hand" Click="BtnFontMinus_Click"/>
                        <Button x:Name="BtnFontPlus" Style="{StaticResource PrimaryButtonStyle}" Content="&#xE8E8;" Width="60" Height="52"
                                FontFamily="Segoe Fluent Icons" FontSize="34" Margin="0,0,50,0" Cursor="Hand" Click="BtnFontPlus_Click"/>
                        <Button x:Name="BtnGo" Style="{StaticResource PrimaryButtonStyle}" Content="&#xE001;" Width="60" Height="52"
                                FontFamily="Segoe Fluent Icons" FontSize="34" Cursor="Hand" Click="BtnGo_Click" Foreground="#FF29C31C"/>
                    </StackPanel>
                </Grid>
            </Grid>

        </DockPanel>
    </Border>
</Window>