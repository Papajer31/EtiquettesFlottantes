<Window x:Class="Étiquettes_Flottantes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:Étiquettes_Flottantes"
        mc:Ignorable="d"
        Title="MainWindow"
        Width="1000" Height="650"
        MinWidth="760" MinHeight="480"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="#1E1E1E">

    <!-- Fenetre sans bord, avec redimensionnement et coins propres -->
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="10" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border CornerRadius="10" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="1" SnapsToDevicePixels="True">

        <DockPanel LastChildFill="True">

            <!-- ===== Top bar (style VS) ===== -->
            <Grid x:Name="TopBar" Height="40" DockPanel.Dock="Top" Background="#252526" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Zone boutons texte -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0">
                    <Button x:Name="BtnExemple" Content="  ●  " Padding="10,0,10,4" Margin="0,0,10,0" Cursor="Hand"
                            Click="BtnExemple_Click" Foreground="White" FontWeight="Bold" FontSize="16"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#2D2D30" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Boutons fenetre -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowButtonStyle}" ToolTip="Réduire" Click="BtnMinimize_Click">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="12" Cursor=""/>
                    </Button>
                    <Button Style="{StaticResource WindowButtonStyle}" ToolTip="Agrandir / Restaurer" Click="BtnMaxRestore_Click">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE922;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                            <Setter Property="Text" Value="&#xE923;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButtonStyle}" ToolTip="Fermer" Click="BtnClose_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== Contenu ===== -->
            <Grid Background="#1E1E1E" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="InputTextBox"
                         Grid.Row="0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontSize="18"
                         Foreground="White"
                         Background="#252526"
                         BorderBrush="#3A3A3A"
                         BorderThickness="1"
                         Padding="12"
                         SpellCheck.IsEnabled="False"/>

                <Button x:Name="BtnGo"
                        Grid.Row="1"
                        Content="GO"
                        Height="52"
                        Margin="0,14,0,0"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnGo_Click"
                        Background="#3C3C3C"
                        Foreground="White"
                        BorderBrush="#505050"
                        BorderThickness="1"/>
            </Grid>

        </DockPanel>
    </Border>
</Window>